{
    "name": "phpnomad/di-container",
    "description": "Lightweight dependency injection container for PHPNomad",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alex Standiford",
            "email": "alex@standiford.us"
        }
    ],
    "require": {
        "phpnomad/di": "^2.0",
        "phpnomad/utils": "^1.0"
    },
    "require-dev": {
        "phpnomad/tests": "^0.1.0"
    },
    "autoload": {
        "psr-4": {
            "PHPNomad\\Di\\Container\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPNomad\\Di\\Container\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
